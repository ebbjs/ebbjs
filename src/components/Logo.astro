---
interface Props {
  width?: number;
}

const { width = 80 } = Astro.props;
---

<div class="logo" style={`width: ${width}px;`}>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 58" fill="none" aria-label="ebb logo">
    <path
      d="M 24 41 C 34 0, 45 0, 60 29 C 75 58, 86 58, 96 17"
      stroke="currentColor"
      stroke-width="9.5"
      stroke-linecap="round"
      fill="none"
    />
    <circle cx="24" cy="41" r="13" fill="currentColor" />
    <circle cx="96" cy="17" r="13" fill="currentColor" />
  </svg>
</div>

<style>
  .logo {
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  .logo svg {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
