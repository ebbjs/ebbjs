---
// A horizontal ASCII divider that sweeps in from left to right on scroll
---

<div data-ascii-divider class="w-full overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <pre class="text-stone-700 text-xs leading-none font-mono select-none text-center overflow-hidden whitespace-nowrap" aria-hidden="true">· · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · · ·</pre>
  </div>
</div>
