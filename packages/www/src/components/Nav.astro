---
// Shared navigation component used across all pages
import logoDark from '../assets/logo-dark.svg';
---

<div class="nav-content">
  <a href="/" class="site-title">
    <img class="logo-img" alt="ebb" src={logoDark.src} width="120" height="58" />
    <span class="title-text">ebb</span>
  </a>
  <div class="right-group">
    <nav class="nav-links">
      <a href="/docs/manifesto">Docs</a>
      <a href="/devlog">Devlog</a>
    </nav>
    <a
      href="https://github.com/ebbjs/ebbjs"
      target="_blank"
      rel="noopener noreferrer"
      class="github-button"
    >
      <svg viewBox="0 0 24 24" width="1.2em" height="1.2em" fill="currentColor" aria-hidden="true">
        <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
      </svg>
      <span class="github-text">Star on GitHub</span>
    </a>
  </div>
</div>

<style>
  .nav-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 100%;
  }

  .site-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: #fafaf9;
    font-weight: 600;
  }

  .site-title:hover {
    opacity: 1;
  }

  .logo-img {
    height: 1.2rem;
    width: auto;
  }

  .title-text {
    font-size: 1rem;
  }

  .right-group {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-links {
    display: none;
    gap: 1.5rem;
    align-items: center;
  }

  @media (min-width: 50rem) {
    .nav-links {
      display: flex;
    }
  }

  .nav-links a {
    color: #a8a29e;
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.15s ease;
  }

  .nav-links a:hover {
    color: #fafaf9;
  }

  .github-button {
    align-items: center;
    border: 1px solid #44403c;
    border-radius: 999rem;
    display: inline-flex;
    font-size: 0.875rem;
    font-weight: 400;
    gap: 0.5em;
    line-height: 1.1875;
    padding: 0.4375rem 1.125rem;
    text-decoration: none;
    color: #fafaf9;
    transition: opacity 0.15s ease;
  }

  .github-button:hover {
    opacity: 0.8;
  }

  .github-button svg {
    flex-shrink: 0;
  }

  .github-text {
    white-space: nowrap;
  }

  @media (max-width: 400px) {
    .github-text {
      display: none;
    }
  }
</style>
