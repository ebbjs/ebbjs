---
// Feature section: Real-time collaboration
// Figma-style mouse cursors moving across a whiteboard canvas with simple shapes
---

<section class="w-full py-16 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
      <!-- Copy -->
      <div data-animate="fade-up" class="opacity-0">
        <svg class="w-4 h-4 text-stone-600 block mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
        <h2 class="text-3xl sm:text-4xl font-bold text-stone-100 tracking-tight mb-6 text-balance">Real-time in no-time.</h2>
        <p class="text-lg text-stone-400 leading-relaxed mb-8">
          Every client gets a local replica that reads and writes instantly. Changes sync to all connected users in real-time — with presence, awareness, and conflict resolution. No polling, no spinners, no plumbing.
        </p>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <span class="font-mono text-stone-600 text-sm mt-0.5 shrink-0">--</span>
            <span class="text-stone-300">Local reads and optimistic writes — zero latency</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="font-mono text-stone-600 text-sm mt-0.5 shrink-0">--</span>
            <span class="text-stone-300">Live presence and real-time updates across clients</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="font-mono text-stone-600 text-sm mt-0.5 shrink-0">--</span>
            <span class="text-stone-300">Custom conflict resolution and no data loss</span>
          </li>
        </ul>
      </div>

      <!-- Whiteboard canvas with cursors -->
      <div data-animate="fade-up" class="opacity-0 flex items-start justify-center lg:justify-end">
        <div class="border border-stone-800 rounded-lg bg-stone-950 w-full lg:min-w-[28rem] overflow-hidden">
          <!-- Title bar -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-stone-800">
            <span class="w-3 h-3 rounded-full bg-stone-800"></span>
            <span class="w-3 h-3 rounded-full bg-stone-800"></span>
            <span class="w-3 h-3 rounded-full bg-stone-800"></span>
          </div>

          <!-- Canvas -->
          <div class="relative min-h-[340px] sm:min-h-[380px]">
            <!-- Dot grid background -->
            <div class="absolute inset-0 rt-dotgrid"></div>

            <!-- Shapes scattered on the canvas -->

            <!-- Rounded rectangle, top-left -->
            <div class="absolute top-[8%] left-[6%] w-32 h-20 sm:w-40 sm:h-24 rounded-xl border border-stone-700/50 bg-stone-800/20"></div>

            <!-- Circle, top-right -->
            <div class="absolute top-[6%] right-[10%] w-20 h-20 sm:w-24 sm:h-24 rounded-full border border-stone-700/50 bg-stone-800/20"></div>

            <!-- Wide rectangle, center -->
            <div class="absolute top-[40%] left-[18%] w-36 h-16 sm:w-44 sm:h-20 rounded-lg border border-stone-700/50 bg-stone-800/20"></div>

            <!-- Square, mid-right -->
            <div class="absolute top-[38%] right-[6%] w-16 h-16 sm:w-20 sm:h-20 rounded-lg border border-stone-700/50 bg-stone-800/20"></div>

            <!-- Diamond, bottom-left -->
            <div class="absolute top-[68%] left-[8%] w-16 h-16 sm:w-20 sm:h-20 rotate-45 rounded border border-stone-700/50 bg-stone-800/20"></div>

            <!-- Pill, bottom-center -->
            <div class="absolute top-[72%] left-[35%] w-32 h-12 sm:w-40 sm:h-14 rounded-full border border-stone-700/50 bg-stone-800/20"></div>

            <!-- Circle, bottom-right -->
            <div class="absolute top-[66%] right-[8%] w-14 h-14 sm:w-18 sm:h-18 rounded-full border border-stone-700/50 bg-stone-800/20"></div>

            <!-- Cursor: You (blue) -->
            <div class="rt-cursor rt-cursor-you absolute pointer-events-none">
              <svg width="16" height="20" viewBox="0 0 16 20" fill="none">
                <path d="M1 1L1 15.5L5.5 11.5L9.5 19L12 18L8 10.5L14 10L1 1Z" fill="#60a5fa" stroke="#1e3a5f" stroke-width="1" stroke-linejoin="round"/>
              </svg>
              <span class="rt-cursor-label bg-blue-400 text-stone-950 text-[10px] font-medium leading-none px-1.5 py-0.5 rounded-sm whitespace-nowrap">You</span>
            </div>

            <!-- Cursor: Alice (amber) -->
            <div class="rt-cursor rt-cursor-alice absolute pointer-events-none">
              <svg width="16" height="20" viewBox="0 0 16 20" fill="none">
                <path d="M1 1L1 15.5L5.5 11.5L9.5 19L12 18L8 10.5L14 10L1 1Z" fill="#fbbf24" stroke="#5c4813" stroke-width="1" stroke-linejoin="round"/>
              </svg>
              <span class="rt-cursor-label bg-amber-400 text-stone-950 text-[10px] font-medium leading-none px-1.5 py-0.5 rounded-sm whitespace-nowrap">Alice</span>
            </div>

            <!-- Cursor: Bob (emerald) -->
            <div class="rt-cursor rt-cursor-bob absolute pointer-events-none">
              <svg width="16" height="20" viewBox="0 0 16 20" fill="none">
                <path d="M1 1L1 15.5L5.5 11.5L9.5 19L12 18L8 10.5L14 10L1 1Z" fill="#34d399" stroke="#14532d" stroke-width="1" stroke-linejoin="round"/>
              </svg>
              <span class="rt-cursor-label bg-emerald-400 text-stone-950 text-[10px] font-medium leading-none px-1.5 py-0.5 rounded-sm whitespace-nowrap">Bob</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Dot grid background */
  .rt-dotgrid {
    background-image: radial-gradient(circle, rgb(68 64 60 / 0.25) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .rt-cursor {
    pointer-events: none;
    will-change: top, left;
  }

  .rt-cursor-label {
    display: inline-block;
    position: relative;
    top: 10px;
    left: 2px;
  }

  /* You: top-left shape → center shape → bottom-right → top-right → bottom-pill → center-left → top-left */
  .rt-cursor-you {
    animation: cursor-you 18s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes cursor-you {
    0%, 2%    { top: 16%; left: 22%; }
    14%, 18%  { top: 42%; left: 45%; }
    30%, 34%  { top: 70%; left: 78%; }
    48%, 52%  { top: 14%; left: 72%; }
    64%, 68%  { top: 74%; left: 48%; }
    82%, 86%  { top: 40%; left: 18%; }
    98%, 100% { top: 16%; left: 22%; }
  }

  /* Alice: bottom-left → top-right → center → bottom-right → top-left → bottom-pill → bottom-left */
  .rt-cursor-alice {
    animation: cursor-alice 18s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes cursor-alice {
    0%, 2%    { top: 68%; left: 18%; }
    14%, 18%  { top: 12%; left: 70%; }
    30%, 34%  { top: 44%; left: 50%; }
    48%, 52%  { top: 72%; left: 80%; }
    64%, 68%  { top: 18%; left: 15%; }
    82%, 86%  { top: 76%; left: 42%; }
    98%, 100% { top: 68%; left: 18%; }
  }

  /* Bob: top-center → bottom-pill → top-right → bottom-left → center-right → top-left → top-center */
  .rt-cursor-bob {
    animation: cursor-bob 18s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes cursor-bob {
    0%, 2%    { top: 14%; left: 45%; }
    14%, 18%  { top: 74%; left: 55%; }
    30%, 34%  { top: 12%; left: 78%; }
    48%, 52%  { top: 70%; left: 22%; }
    64%, 68%  { top: 44%; left: 76%; }
    82%, 86%  { top: 16%; left: 12%; }
    98%, 100% { top: 14%; left: 45%; }
  }
</style>
