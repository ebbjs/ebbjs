---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-stone-800 py-8 mt-auto">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-stone-400 text-sm">
      <p>&copy; {currentYear} ebb. All rights reserved.</p>
      <nav class="flex gap-6">
        <a href="https://github.com/ebbjs/ebbjs" target="_blank" rel="noopener noreferrer" class="hover:text-stone-200 transition-colors">
          GitHub
        </a>
      </nav>
    </div>
  </div>
</footer>
