---
import WaitlistForm from './WaitlistForm.astro';
import AsciiWaveBackground from './AsciiWaveBackground.astro';
---

<section data-animate="fade-up" class="opacity-0 relative w-full pt-24 pb-24 sm:pt-32 sm:pb-32">
  <AsciiWaveBackground />
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-stone-100 tracking-tight mb-4">Stay in sync</h2>
      <p class="text-lg text-stone-400 mb-10">Ebb is in early development. Sign up to receive updates.</p>

      <WaitlistForm id="bottom-waitlist" />
    </div>
  </div>
</section>
