---
import Marketing from '../layouts/Marketing.astro';
import AsciiWaveBackground from '../components/AsciiWaveBackground.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
import AsciiDivider from '../components/AsciiDivider.astro';
import ValuePropBar from '../components/ValuePropBar.astro';
import FeatureDX from '../components/FeatureDX.astro';
import FeatureDeploy from '../components/FeatureDeploy.astro';
import FeaturePerformance from '../components/FeaturePerformance.astro';
import BottomCTA from '../components/BottomCTA.astro';
import Roadmap from '../components/Roadmap.astro';
---

<Marketing title="ebb — the real-time backend">
  <!-- Hero -->
  <section class="relative min-h-[calc(100dvh-var(--spacing-nav))] flex items-center justify-center px-4">
    <AsciiWaveBackground />
    <div class="text-center" data-animate="hero">
      <svg class="hidden sm:block h-8 w-auto mx-auto mb-6 text-stone-100" viewBox="0 0 120 58" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M 24 41 C 34 0, 45 0, 60 29 C 75 58, 86 58, 96 17"
          stroke="currentColor"
          stroke-width="9.5"
          stroke-linecap="round"
          fill="none"
        />
        <circle cx="24" cy="41" r="13" fill="currentColor" />
        <circle cx="96" cy="17" r="13" fill="currentColor" />
      </svg>

      <h1 class="text-4xl sm:text-6xl font-bold tracking-tight mb-4 text-balance max-w-4xl mx-auto">Build apps that are fast, work offline, and just sync.</h1>
      <p class="text-lg sm:text-xl text-stone-400 mb-8 text-balance max-w-xl mx-auto">The real-time backend for your vibe coded frontend.</p>

      <WaitlistForm id="hero-waitlist" />
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-stone-600 animate-bounce">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </div>
  </section>

  <AsciiDivider />
  <ValuePropBar />
  <AsciiDivider />
  <FeatureDX />
  <AsciiDivider />
  <FeatureDeploy />
  <AsciiDivider />
  <FeaturePerformance />
  <AsciiDivider />
  <Roadmap />
  <AsciiDivider />
  <BottomCTA />
</Marketing>

<script>
  import { animate, inView, stagger } from 'motion';

  function initAnimations() {
    // Hero fade in on load
    const hero = document.querySelector('[data-animate="hero"]');
    if (hero instanceof HTMLElement) {
      animate(
        hero,
        { opacity: [0, 1], transform: ['translateY(16px)', 'translateY(0)'] },
        { duration: 0.8, easing: 'ease-out' },
      );
    }

    // Fade-up elements on scroll
    document.querySelectorAll<HTMLElement>('[data-animate="fade-up"]').forEach((el) => {
      inView(el, () => {
        animate(
          el,
          { opacity: [0, 1], transform: ['translateY(24px)', 'translateY(0)'] },
          { duration: 0.6, easing: 'ease-out' },
        );
      }, { amount: 0.2 });
    });

    // Staggered children
    document.querySelectorAll<HTMLElement>('[data-animate="stagger"]').forEach((parent) => {
      const children = parent.querySelectorAll<HTMLElement>('[data-animate="fade-up"]');
      if (children.length === 0) return;

      inView(parent, () => {
        animate(
          children,
          { opacity: [0, 1], transform: ['translateY(24px)', 'translateY(0)'] },
          { duration: 0.6, easing: 'ease-out', delay: stagger(0.15) },
        );
      }, { amount: 0.2 });
    });

    // ASCII divider sweep
    document.querySelectorAll<HTMLElement>('[data-ascii-divider]').forEach((el) => {
      inView(el, () => {
        animate(
          el,
          { opacity: [0, 1] },
          { duration: 0.8, easing: 'ease-out' },
        );
      }, { amount: 0.5 });
    });
  }

  initAnimations();
  document.addEventListener('astro:after-swap', initAnimations);
</script>
