---
export const prerender = false;

import { getCollection } from 'astro:content';
import Marketing from '../../layouts/Marketing.astro';

const showAll = Astro.url.searchParams.has('all');

const posts = (await getCollection('devlog'))
.filter((post) => showAll || post.data.published)
.sort((a,b) => b.data.date.getTime() - a.data.date.getTime())

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<Marketing title="Devlog | ebb" description="Development updates and notes from building ebb.">
  <div class="mx-auto max-w-3xl py-12">
    <div class="px-4 sm:px-6 ">
    <h1 class="text-4xl font-bold tracking-tight mb-4">Devlog</h1>
    <p class="text-stone-400 text-lg mb-12">Development updates and notes from building ebb.</p>
</div>
    {posts.length === 0 ? (
      <p class="text-stone-400 italic">No posts yet. Check back soon!</p>
    ) : (
      <div> 
        {posts.map((post) => (
            <a
              href={`/devlog/${post.id}`}
              class="block px-4 sm:px-6 py-6 border-t last:border-b border-stone-800 hover:bg-stone-900/50 transition-colors"
            >
              <time datetime={post.data.date.toISOString()} class="text-sm text-stone-400">
                {formatDate(post.data.date)}
              </time>
              <h2 class="text-xl font-semibold mt-1 mb-2">{post.data.title}</h2>
              <p class="text-stone-400">{post.data.description}</p>
            </a>
        ))}
      </div>
    )}
  </div>
</Marketing>
