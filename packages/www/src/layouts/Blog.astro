---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/TableOfContents.astro';
import AuthorFooter from '../components/AuthorFooter.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  ogImage?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, date, ogImage, headings = [] } = Astro.props;

// Filter to h2 and h3 only for TOC
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const hasToc = tocHeadings.length > 0;

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<Base title={`${title} — ebb`} description={description} ogImage={ogImage}>
  <div class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-50 border-b border-stone-800 bg-stone-950/80 backdrop-blur-sm">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 h-16">
        <Nav />
      </div>
    </header>
    
    <div class="flex-1 mx-auto max-w-7xl w-full px-4 sm:px-6 lg:px-8">
      <div class:list={["max-w-4xl mx-auto", hasToc && "lg:grid lg:grid-cols-[1fr_220px] lg:gap-8 lg:max-w-none"]}>
        <!-- Main content -->
        <main class="py-8 max-w-3xl mx-auto">
          <article>
            <a href="/devlog" class="inline-flex items-center gap-1 text-stone-400 hover:text-stone-200 text-sm mb-6 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m15 18-6-6 6-6"/>
              </svg>
              Back to Devlog
            </a>
            
            <h1 class="text-4xl font-bold tracking-tight mb-2">{title}</h1>
            
            <time datetime={date.toISOString()} class="block text-stone-400 text-sm mb-8">
              {formatDate(date)}
            </time>
            
            <div class="prose">
              <slot />
            </div>
            
            <AuthorFooter />
          </article>
        </main>
        
        <!-- Table of Contents -->
        {hasToc && (
          <aside class="hidden lg:block py-8">
            <div class="sticky top-24">
              <TableOfContents headings={tocHeadings} />
            </div>
          </aside>
        )}
      </div>
    </div>
    
    <Footer />
  </div>
</Base>

<style>
  .prose {
    font-size: 1.125rem;
  }
</style>
