{
  "name": "@ebbjs/server",
  "version": "0.0.1",
  "private": true,
  "description": "Server runtime tooling — spawns ebb_server, seeds data, provides test harness",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/ensure-server-binary.js && vite build",
    "build:local": "bash scripts/build-release.sh",
    "dev": "vite build --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm --root ../../ lint",
    "lint:fix": "pnpm --root ../../ lint:fix",
    "fmt": "pnpm --root ../../ fmt",
    "fmt:check": "pnpm --root ../../ fmt:check"
  },
  "dependencies": {
    "@ebbjs/core": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.20.4",
    "vitest": "^3.2.4"
  }
}
